{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap register"
          },
          {
            "type": "command",
            "command": "~/.soap/soap add-key claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap unregister"
          },
          {
            "type": "command",
            "command": "~/.soap/soap remove-key claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap remove-key claude-processing"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap add-key claude-processing"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap remove-key claude-processing"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.soap/soap remove-key claude-processing"
          }
        ]
      }
    ]
  }
}
